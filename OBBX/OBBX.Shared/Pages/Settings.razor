@page "/settings"
@using OBBX.Shared.ViewModels
@inject SettingsViewModel VM

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Settings</MudText>
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard>
                <MudText Typo="Typo.h6" Class="pa-4">Challonge Settings</MudText>
                <MudCardContent>
                    <MudTextField @bind-Value="VM.Settings.Challonge.ApiKey" Label="API Key" Variant="Variant.Outlined" FullWidth="true"
                        Adornment="Adornment.End" AdornmentIcon="@VM.ApiKeyInputIcon"
                        OnAdornmentClick="VM.ToggleApiKeyVisibility" AdornmentAriaLabel="Show API Key" InputType="@VM.ApiKeyInput" />
                    <MudTextField @bind-Value="VM.Settings.Challonge.Username" Label="Username" Variant="Variant.Outlined" FullWidth="true"
                        Class="mt-4" />
                    <MudTextField @bind-Value="VM.Settings.Challonge.Uri" Label="URL" Variant="Variant.Outlined" FullWidth="true" Class="mt-4" />
                    <MudTextField @bind-Value="VM.Settings.Challonge.RefreshIntervalSeconds" T="int" Label="Refresh Interval (seconds)" Variant="Variant.Outlined" FullWidth="true"
                        Class="mt-4" />
                </MudCardContent>
            </MudCard>


        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard>
                <MudText Typo="Typo.h6" Class="pa-4">OBS Websocket Settings</MudText>
                <MudCardContent>
                    <MudTextField @bind-Value="VM.Settings.OBSWebSocket.Address" Label="Address" Variant="Variant.Outlined" FullWidth="true" />
                    <MudTextField @bind-Value="VM.Settings.OBSWebSocket.Port" T="int" Label="Port" Variant="Variant.Outlined" FullWidth="true" Class="mt-4" />
                    <MudTextField @bind-Value="VM.Settings.OBSWebSocket.Key" T="string" Label="Server Password" Variant="Variant.Outlined" FullWidth="true"
                        Class="mt-4" Adornment="Adornment.End" AdornmentIcon="@VM.PasswordInputIcon"
                        OnAdornmentClick="VM.TogglePasswordVisibility" AdornmentAriaLabel="Show Password"
                        InputType="@VM.PasswordInput" />
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12">
            <MudCard>
                <MudText Typo="Typo.h6" Class="pa-4">CSV Blader Data Import</MudText>
                <MudCardContent>
                    <MudTextField Value="@VM.CsvImportDisplay" Label="CSV File Path" Variant="Variant.Outlined" FullWidth="true" Disabled="true" />         
                    <!-- Browser file input for web (Firefox) -->
                    <InputFile OnChange="OnCsvFileSelected" accept=".csv" class="mt-2" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
       <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-4" 
        OnClick="@VM.SaveSettingsAsync" Disabled="@VM.IsSaving" ButtonType="ButtonType.Button">
        Save Settings
    </MudButton>
</MudContainer>

@code {
    private async Task OnCsvFileSelected(InputFileChangeEventArgs e)
    {
        await VM.ImportCsvFromBrowser(e);
    }

    protected override async Task OnInitializedAsync()
    {
        VM.OnChanged += () => InvokeAsync(StateHasChanged);
        await VM.InitializeAsync();
    }
}