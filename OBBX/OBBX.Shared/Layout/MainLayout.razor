@inherits LayoutComponentBase
@inject OBBX.Shared.Services.ChallongeService ChallongeService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudThemeProvider theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudButton Href="/" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.AutoAwesomeMosaic">Dashboard
        </MudButton>
        <MudButton Href="/tables" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.HotTub">Tables</MudButton>
        <MudButton Href="/settings" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Settings">Settings
        </MudButton>
    </MudAppBar>

    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ChallongeService.InitChallongeClientAsync();

            if (!ChallongeService.IsConfigured)
            {
                Snackbar.Add($"{ChallongeService.ConfigurationError} Please check your settings.", 
                    Severity.Warning, config => 
                {
                    config.OnClick = snackbar => {
                        Nav.NavigateTo("/settings");
                        return Task.CompletedTask;
                    };
                });
            }
        }
    }

    private MudTheme _theme = new MudTheme
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#c6ff00",
            Secondary = "#ffffff",
            Background = "#0a0a0a",
            Surface = "#1a1a1a",
            AppbarBackground = "#0a0a0a",
            AppbarText = "#ffffff",
            TextPrimary = "#ffffff",
            TextSecondary = "#b0b0b0",
            ActionDefault = "#c6ff00",
            DrawerBackground = "#0a0a0a",
            DrawerText = "#ffffff"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "BigNoodleTitling", "Arial" }
            }
        }
    };
}