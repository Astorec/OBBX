@using OBBX.Shared.Models
@using System.Text.RegularExpressions
@layout EmptyLayout

@{
    // Get the specific matches for this page and round
    var pagedData = GetPagedMatches(MatchesByRound);

    // Find how many matches are actually being shown to determine the scale
    var currentMatchCount = pagedData.Values.FirstOrDefault()?.Count ?? 0;
    var scaleClass = GetScaleClass(currentMatchCount);
}

<div class="obs-dashboard @scaleClass">
    @foreach (var round in pagedData)
    {
        <div class="round-header-full">
            <MudText Typo="Typo.h4" Style="color: var(--mud-palette-primary); font-weight: 900;">
                @if (round.Key > 0)
                {
                    @:Winner Bracket - Round @round.Key @(Page > 0 ? $"(Page {Page})" : "")
                }
                else if (round.Key < 0)
                {
                    @:Loser Bracket - Round @Math.Abs(round.Key) @(Page > 0 ? $"(Page {Page})" : "")
                }
            </MudText>
        </div>

        <div class="grid-safe-zone">
            <MudGrid Spacing="2" Class="pa-4">
                @foreach (var match in round.Value)
                {
                    var p1Winner = match.WinnerId == match.Player1Id && match.State == TournamentMatchState.Complete;
                    var p2Winner = match.WinnerId == match.Player2Id && match.State == TournamentMatchState.Complete;

                    <MudItem xs="12" sm="3">
                        <MudPaper Elevation="0" Class="match-container">
                            @* Player 1 Row *@
                            <div class="player-row @(p1Winner ? "is-winner" : "")">
                                <MudText Typo="Typo.button" Class="player-name">@(match.Player1Name ?? "TBD")</MudText>
                                <MudText Typo="Typo.h6" Class="player-score">@GetScore(match, 0)</MudText>
                            </div>

                            <MudDivider Style="background-color: rgba(255,255,255,0.05);" />

                            @* Player 2 Row *@
                            <div class="player-row @(p2Winner ? "is-winner" : "")">
                                <MudText Typo="Typo.button" Class="player-name">@(match.Player2Name ?? "TBD")</MudText>
                                <MudText Typo="Typo.h6" Class="player-score">@GetScore(match, 1)</MudText>
                            </div>

                            @if (match.TableNumber > 0)
                            {
                                <div class="tbl-badge">TBL @match.TableNumber</div>
                            }
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </div>
    }
</div>
<style>
    /* Force the background and prevent scrolling */
    .obs-dashboard {
        width: 100vw;
        height: 100vh;
        background-color: #0a0a0a;
        overflow: hidden;
        padding: 20px;
        position: fixed;
        top: 0;
        left: 0;
    }

    .grid-safe-zone {
        height: calc(100vh - 100px);
        width: 100%;
        overflow: hidden;
    }

    .round-header-full {
        border-bottom: 3px solid #c6ff00;
        margin-bottom: 20px;
        padding-left: 10px;
        width: 100%;
    }

    /* Match Box Styling */
    .match-container {
        background-color: #1a1a1a !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        transition: transform 0.2s;
    }

    .player-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 15px;
        color: #ffffff;
    }

    /* Winner highlight using your Primary #c6ff00 */
    .player-row.is-winner {
        background: linear-gradient(90deg, rgba(198, 255, 0, 0.2) 0%, transparent 100%);
        color: #c6ff00 !important;
    }

    .player-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .player-score {
        font-family: 'Courier New', Courier, monospace;
        color: #c6ff00;
        min-width: 25px;
        text-align: right;
    }

    .tbl-badge {
        position: absolute;
        top: 0;
        right: 0;
        background-color: #c6ff00;
        color: #000;
        font-size: 0.7rem;
        font-weight: bold;
        padding: 0 5px;
        border-bottom-left-radius: 4px;
    }

    /* Dynamic Sizing based on match count */
    .match-grid {
        display: grid;
        gap: 20px;
        width: 100%;
        align-content: center;
    }

    /* 1-8 Matches: Huge for "Feature" rounds */
    .scale-huge .match-container {
        height: 180px;
    }

    .scale-huge .player-name {
        font-size: 2.5rem;
    }

    .scale-huge .player-score {
        font-size: 3rem;
    }

    /* 8-16 Matches: Standard Large */
    .scale-large .match-container {
        height: 120px;
    }

    .scale-large .player-name {
        font-size: 1.8rem;
    }

    .scale-large .player-score {
        font-size: 2rem;
    }

    .scale-compact .match-container {
        height: 80px;
    }

    .scale-compact .player-name {
        font-size: 1.2rem;
    }

    .scale-compact .player-score {
        font-size: 1.4rem;
    }
</style>

@code {
    [Parameter] public Dictionary<int, List<TournamentMatch>> MatchesByRound { get; set; } = new();
    [Parameter] public int? Round { get; set; }
    [Parameter] public bool IsCompact { get; set; } = false;
    [Parameter] public Dictionary<long, int>? PlayerSeeds { get; set; }
    [Parameter] public int Page { get; set; } = 1;

    private int MatchesPerPage = 32;

    private string GetRootClass() => IsCompact ? "swiss-bracket-root bracket-compact" : "swiss-bracket-root";

    private string GetScore(TournamentMatch match, int playerIndex)
    {
        if (string.IsNullOrEmpty(match.ScoresCsv)) return "-";
        try
        {
            var pattern = playerIndex == 0 ? "PlayerOneScore\\s*=\\s*(\\d+)" : "PlayerTwoScore\\s*=\\s*(\\d+)";
            var regexMatches = Regex.Matches(match.ScoresCsv, pattern);
            if (regexMatches.Count == 0) return "-";

            var totalScore = 0;
            foreach (Match m in regexMatches)
            {
                if (int.TryParse(m.Groups[1].Value, out var score)) totalScore += score;
            }
            return totalScore.ToString();
        }
        catch { return "-"; }
    }

    private Dictionary<int, List<TournamentMatch>> GetPagedMatches(Dictionary<int, List<TournamentMatch>> source)
    {
        if (source == null || !source.Any()) return new();

        // 1. Determine which round to show
        int roundToHandle;
        if (Round.HasValue)
        {
            roundToHandle = Round.Value;
        }
        else
        {
            // Auto-detect: Find the first round that has an 'Open' or 'Pending' match
            // Fallback to the first round if all are complete
            roundToHandle = source
                .OrderBy(r => r.Key)
                .FirstOrDefault(r => r.Value.Any(m => m.State != TournamentMatchState.Complete)).Key;

            if (roundToHandle == 0 && source.Any()) roundToHandle = source.Keys.Min();
        }

        if (!source.ContainsKey(roundToHandle)) return new();

        // 2. Paginate the matches for that round
        var allMatches = source[roundToHandle];
        var pagedList = allMatches
            .Skip((Page - 1) * MatchesPerPage)
            .Take(MatchesPerPage)
            .ToList();

        return new Dictionary<int, List<TournamentMatch>> { { roundToHandle, pagedList } };
    }

    private string GetScaleClass(int matchCount)
    {
        if (matchCount <= 8) return "scale-huge";
        if (matchCount <= 16) return "scale-large";
        return "scale-compact";
    }
}