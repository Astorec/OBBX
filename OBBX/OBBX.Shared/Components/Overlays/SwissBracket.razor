@using OBBX.Shared.Models
@using System.Text.RegularExpressions

<div class="obs-dashboard">
    @foreach (var round in MatchesByRound.OrderBy(r => r.Key))
    {
        <div class="round-header-full">
            <MudText Typo="Typo.h4" Style="color: var(--mud-palette-primary); font-weight: 900;">
                ROUND @round.Key
            </MudText>
        </div>

        <div class="grid-safe-zone">
            <MudGrid Spacing="2" Class="pa-4">
                @foreach (var match in round.Value)
                {
                    var p1Winner = match.WinnerId == match.Player1Id && match.State == TournamentMatchState.Complete;
                    var p2Winner = match.WinnerId == match.Player2Id && match.State == TournamentMatchState.Complete;

                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudPaper Elevation="0" Class="match-container">
                            @* Player 1 Row *@
                            <div class="player-row @(p1Winner ? "is-winner" : "")">
                                <MudText Typo="Typo.button" Class="player-name">@(match.Player1Name ?? "TBD")</MudText>
                                <MudText Typo="Typo.h6" Class="player-score">@GetScore(match, 0)</MudText>
                            </div>

                            <MudDivider Style="background-color: rgba(255,255,255,0.05);" />

                            @* Player 2 Row *@
                            <div class="player-row @(p2Winner ? "is-winner" : "")">
                                <MudText Typo="Typo.button" Class="player-name">@(match.Player2Name ?? "TBD")</MudText>
                                <MudText Typo="Typo.h6" Class="player-score">@GetScore(match, 1)</MudText>
                            </div>
                        </MudPaper>
                        <MudPaper Elevation="0" Class="match-container mt-1 d-flex justify-center align-center py-1">
                            <MudText Typo="Typo.button"
                                     Style="color: var(--mud-palette-secondary); font-weight: bold; text-align: center;">
                                @if (match.TableNumber > 0)
                                {
                                    <span>Table @match.TableNumber</span>
                                }
                                else if (match.State == TournamentMatchState.Complete)
                                {
                                    <span>Complete</span>
                                }
                                else
                                {
                                    <span>TBC</span>
                                }
                            </MudText>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </div>
    }
</div>

<style>
    /* Force the background and prevent scrolling */
    .obs-dashboard {
        width: 100vw;
        height: 100vh;
        background-color: #0a0a0a;
        overflow: hidden;
        padding: 20px;
        position: fixed;
        top: 0;
        left: 0;
    }

    .grid-safe-zone {
        height: calc(100vh - 100px);
        width: 100%;
        overflow: hidden;
    }

    .round-header-full {
        border-bottom: 3px solid #c6ff00;
        margin-bottom: 20px;
        padding-left: 10px;
        width: 100%;
    }

    /* Match Box Styling */
    .match-container {
        background-color: #1a1a1a !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        transition: transform 0.2s;
    }

    .player-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 15px;
        color: #ffffff;
    }

    /* Winner highlight using your Primary #c6ff00 */
    .player-row.is-winner {
        background: linear-gradient(90deg, rgba(198, 255, 0, 0.2) 0%, transparent 100%);
        color: #c6ff00 !important;
    }

    .player-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .player-score {
        font-family: 'Courier New', Courier, monospace;
        color: #c6ff00;
        min-width: 25px;
        text-align: right;
    }

    .tbl-badge {
        position: absolute;
        top: 0;
        right: 0;
        background-color: #c6ff00;
        color: #000;
        font-size: 0.7rem;
        font-weight: bold;
        padding: 0 5px;
        border-bottom-left-radius: 4px;
    }
</style>

@code {
    [Parameter] public Dictionary<int, List<TournamentMatch>> MatchesByRound { get; set; } = new();
    [Parameter] public bool ShowSeeds { get; set; } = true;
    [Parameter] public bool IsCompact { get; set; } = false;
    [Parameter] public Dictionary<long, int>? PlayerSeeds { get; set; }

    private string GetRootClass() => IsCompact ? "swiss-bracket-root bracket-compact" : "swiss-bracket-root";

    private string GetScore(TournamentMatch match, int playerIndex)
    {
        if (string.IsNullOrEmpty(match.ScoresCsv)) return "-";
        try
        {
            var pattern = playerIndex == 0 ? "PlayerOneScore\\s*=\\s*(\\d+)" : "PlayerTwoScore\\s*=\\s*(\\d+)";
            var regexMatches = Regex.Matches(match.ScoresCsv, pattern);
            if (regexMatches.Count == 0) return "-";

            var totalScore = 0;
            foreach (Match m in regexMatches)
            {
                if (int.TryParse(m.Groups[1].Value, out var score)) totalScore += score;
            }
            return totalScore.ToString();
        }
        catch { return "-"; }
    }
}